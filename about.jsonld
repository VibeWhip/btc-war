    {
      "@type": "DefinedTerm",
      "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#term-bitcoin-price",
      "name": "Bitcoin price",
      "description": "The price of the most recent matched trade for a specific Bitcoin trading pair on an observed market.",
      "inDefinedTermSet": {
        "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#terms"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#term-best-bid",
      "name": "Best bid",
      "description": "The highest visible price at which a buyer is currently offering to trade.",
      "inDefinedTermSet": {
        "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#terms"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#term-best-ask",
      "name": "Best ask",
      "description": "The lowest visible price at which a seller is currently offering to trade.",
      "inDefinedTermSet": {
        "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#terms"
      }
    },
    {
      "@type": "DefinedTerm",
      "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#term-spread",
      "name": "Bid-ask spread",
      "description": "The difference between the best visible bid and best visible ask.",
      "inDefinedTermSet": {
        "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#terms"
      }
    },
