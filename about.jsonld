      "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#term-order-book",
      "name": "Bitcoin order book",
      "description": "A snapshot of resting limit orders, with visible bids below the market and asks above it.",
      "inDefinedTermSet": {
        "@id": "https://vibewhip.github.io/btc-war/bitcoin-price-market-depth-order-flow/#terms"
      }
    },
